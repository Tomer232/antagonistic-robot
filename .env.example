# Antagonistic Robot — Environment Variables
# Copy this file to .env and fill in your API keys.
#
#   cp .env.example .env

# LLM API key (Grok / x.ai or any OpenAI-compatible provider)
GROK_API_KEY=your-api-key-here

# OpenAI API key (used for TTS via gpt-4o-mini-tts)
OPENAI_API_KEY=your-api-key-here
